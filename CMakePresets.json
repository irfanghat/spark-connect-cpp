{
  "version": 2,
  "configurePresets": [
    {
      "name": "vcpkg",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/vcpkg-package/scripts/buildsystems/vcpkg.cmake"
      },
      "hidden": true
    },
    {
      "name": "prod",
      "inherits": "vcpkg",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "/usr/bin/cc",
        "CMAKE_CXX_COMPILER": "/usr/bin/c++",
        "CMAKE_BUILD_TYPE": "Release"
      },
      "environment": {
        "ENABLE_COVERAGE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "displayName": "Spark Release Build",
      "configurePreset": "prod",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "test_coverage",
      "displayName": "Spark Test Coverage",
      "configurePreset": "prod",
      "filter": {
        "exclude": {
          "name": "Databricks"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
