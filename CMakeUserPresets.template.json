{
  "version": 2,
  "configurePresets": [
    {
      "name": "spark",
      "inherits": "vcpkg",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "",
        "CMAKE_CXX_COMPILER": ""
      },
      "environment": {
        "VCPKG_ROOT": ""
      }
    },
    {
      "name": "debug",
      "inherits": "spark",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": "spark",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Spark Debug Build",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "displayName": "Spark Release Build",
      "configurePreset": "release"
    }
  ]
}
