#!/bin/bash

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

PRESET="pr"
TEST_PRESET="test_pr_spark_coverage"

echo -e "${BLUE}*********************************************${NC}"
echo -e "${BLUE}  Pre-Push Hook: Run Tests (Presets)${NC}"
echo -e "${BLUE}*********************************************${NC}"
echo ""

current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")

echo -e "${YELLOW}Branch:${NC} $current_branch"
echo -e "${YELLOW}Remote:${NC} $1"
echo ""

echo -e "${BLUE}Configuring project (preset: ${PRESET})...${NC}"
if ! cmake --preset ${PRESET}; then
    echo -e "${RED}CMake configuration failed${NC}"
    exit 1
fi

echo ""
echo -e "${BLUE}Building project...${NC}"
if ! cmake --build --preset ${PRESET}; then
    echo ""
    echo -e "${RED}Build failed${NC}"
    echo -e "${YELLOW}Fix build errors before pushing.${NC}"
    echo -e "${YELLOW}To push anyway: git push --no-verify${NC}"
    exit 1
fi

echo ""
echo -e "${BLUE}Running tests (preset: ${TEST_PRESET})...${NC}"
echo ""

if ! ctest --preset ${TEST_PRESET}; then
    echo ""
    echo -e "${RED}*********************************************${NC}"
    echo -e "${RED} TESTS FAILED${NC}"
    echo -e "${RED}*********************************************${NC}"
    echo ""

    echo -e "${YELLOW}If failures are integration-related:${NC}"
    echo -e "${YELLOW}  docker compose up spark --build${NC}"
    echo ""

    echo -e "${YELLOW}Fix failing tests before pushing.${NC}"
    echo -e "${YELLOW}To push anyway: git push --no-verify${NC}"
    echo ""
    exit 1
fi

echo ""
echo -e "${GREEN}*********************************************${NC}"
echo -e "${GREEN} ALL TESTS PASSED${NC}"
echo -e "${GREEN}*********************************************${NC}"
echo -e "${GREEN}Proceeding with push...${NC}"
echo ""

exit 0