#!/bin/bash

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

PRESET="pr_pipeline"
TEST_PRESET="test_pr_pip_coverage"

echo -e "${BLUE}********************************************${NC}"
echo -e "${BLUE}  Pre-Commit Hook: CMake Preset Check${NC}"
echo -e "${BLUE}********************************************${NC}"
echo ""

echo -e "${BLUE}Configuring project (preset: ${PRESET})...${NC}"
if ! cmake --preset ${PRESET}; then
    echo -e "${RED}CMake configuration failed${NC}"
    exit 1
fi

echo ""
echo "Running clang-format..."

clang-format -i $(git diff --cached --name-only --diff-filter=ACM | grep -E '\.cpp$|\.h$')
git add $(git diff --cached --name-only --diff-filter=ACM | grep -E '\.cpp$|\.h$')

echo ""
echo -e "${BLUE}Building project...${NC}"
if ! cmake --build --preset ${PRESET}; then
    echo ""
    echo -e "${RED}Build failed${NC}"
    echo -e "${YELLOW}Fix build errors before committing.${NC}"
    echo -e "${YELLOW}To commit anyway: git commit --no-verify${NC}"
    exit 1
fi

echo ""
echo -e "${GREEN}All checks passed${NC}"
echo ""

exit 0