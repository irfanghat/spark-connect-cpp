#!/bin/bash

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

PRESET="pr_pipeline"

echo -e "${YELLOW}--------------------------------------------${NC}"
echo -e "${YELLOW}  Pre-Commit Hook: Format + Build Check${NC}"
echo -e "${YELLOW}--------------------------------------------${NC}"
echo ""

echo -e "${YELLOW}Configuring project (preset: ${PRESET})...${NC}"
cmake --preset ${PRESET}

echo ""
echo -e "${BLUE}Running clang-format...${NC}"

FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|h)$' || true)

if [ -n "$FILES" ]; then
    echo "$FILES" | while read -r file; do
        clang-format -i "$file"
        git add "$file"
    done
else
    echo -e "${YELLOW}No C++ files to format${NC}"
fi

echo ""
echo -e "${BLUE}Building project...${NC}"
echo ""

cmake --build --preset ${PRESET}

echo ""
echo -e "${GREEN}All checks passed${NC}"
echo ""

exit 0